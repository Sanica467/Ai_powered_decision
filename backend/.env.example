# ============================================================================
# DecisionAI Backend - Environment Variables
# Copy this file to .env and fill in the values
# ============================================================================

# ---- Application ----
APP_NAME=DecisionAI
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Security ----
SECRET_KEY=change-me-to-a-long-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Database (Supabase PostgreSQL) ----
# Use the connection pooler URL from Supabase: Settings -> Database -> Connection string
DATABASE_URL=postgresql+psycopg2://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# ---- Google Gemini API ----
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# ---- Uploads ----
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=uploads
REPORT_DIR=generated_reports

# ---- Rate Limiting ----
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=60/minute

# ---- Logging ----
LOG_LEVEL=INFO
LOG_DIR=logs
